# =============================================================================
# ENVIRONMENT VARIABLES — EXAMPLE FILE
# Copy this to .dev.vars for local Wrangler development.
# Never commit .dev.vars or any file with real credentials.
# In production, use: wrangler secret put <KEY_NAME>
# =============================================================================

# ---- Cloudflare AI Gateway ----
# Your AI Gateway endpoint from: https://dash.cloudflare.com > AI > AI Gateway
CF_AI_GATEWAY_ENDPOINT=https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}

# ---- Anthropic / OpenAI (fallback LLM via AI Gateway) ----
# Set via: wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME

# ---- PagerDuty ----
# Webhook signing secret from PagerDuty > Integrations > Webhooks
PAGERDUTY_WEBHOOK_SECRET=REPLACE_ME
PAGERDUTY_API_KEY=REPLACE_ME

# ---- Datadog ----
DATADOG_API_KEY=REPLACE_ME
DATADOG_APP_KEY=REPLACE_ME
DATADOG_SITE=datadoghq.com

# ---- AWS CloudWatch (customer infra) ----
# Use IAM role with least-privilege (read-only CloudWatch + Logs)
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=REPLACE_ME

# ---- Slack ----
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
SLACK_INCIDENT_CHANNEL_ID=REPLACE_ME

# ---- GitHub ----
# Fine-grained PAT: repo read + PR create only (least privilege)
GITHUB_TOKEN=github_pat_REPLACE_ME
GITHUB_REPO_OWNER=REPLACE_ME
GITHUB_REPO_NAME=REPLACE_ME

# ---- Jira ----
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=REPLACE_ME
JIRA_API_TOKEN=REPLACE_ME
JIRA_PROJECT_KEY=SRE

# ---- ArgoCD ----
ARGOCD_SERVER_URL=https://argocd.internal.example.com
ARGOCD_TOKEN=REPLACE_ME

# ---- Tenant Config (for local dev — single tenant) ----
DEFAULT_TENANT_ID=dev-tenant-001
